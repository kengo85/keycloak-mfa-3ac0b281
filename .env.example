# Copy to .env and fill in real values. Never commit the real .env file.

# Public hostname this server is reached at (must be HTTPS in production)
KC_HOSTNAME=https://mfa.example.com

# Set only if Keycloak sits behind a TLS-terminating reverse proxy/load balancer
# (recommended). Leave unset if Keycloak terminates TLS itself.
KC_PROXY_HEADERS=xforwarded

# PostgreSQL password (used by both the postgres and keycloak services)
KC_DB_PASSWORD=change-me

# Bootstrap admin account created on first startup
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me
